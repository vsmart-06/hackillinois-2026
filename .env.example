# PostgreSQL: use either DATABASE_URL or DB_* (credentials are read from this file).
# Create a DB first, e.g. createdb relayroute

# Option A: single URL
# DATABASE_URL=postgresql://user:password@localhost:5432/relayroute

# Option B: separate credentials (URL is built automatically)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=relayroute

# Optional: for city setup (Google Places, Distance Matrix, Geocoding)
# GOOGLE_MAPS_API_KEY=your-key

# Optional: for AI zone reasoning on setup
# OPENAI_API_KEY=your-key
